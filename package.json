{
  "name": "ReHook",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:api": "bun --cwd apps/api dev",
    "test:api": "bun --cwd apps/api test",
    "db:generate": "bun --cwd apps/api db:generate",
    "db:migrate": "bun --cwd apps/api db:migrate",
    "db:push": "bun --cwd apps/api db:push",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.10.5",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "devEngines": {
    "packageManager": {
      "name": "bun",
      "version": "1.3.11"
    }
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
