{
  "name": "@rehook/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/server.ts",
    "dev:worker": "bun --watch src/workers/init.ts",
    "build": "tsc --noEmit",
    "db:generate": "prisma generate --schema=prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=prisma/schema.prisma",
    "db:push": "prisma db push --schema=prisma/schema.prisma",
    "mock:receiver": "bun src/scripts/mockReceiver.ts",
    "benchmark": "bun src/scripts/benchmark.ts",
    "test": "bun test"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bullmq": "^5.41.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "ioredis": "^5.5.0",
    "prom-client": "^15.1.3",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.9",
    "@types/supertest": "^7.2.1",
    "@types/swagger-ui-express": "^4.1.8",
    "bun-types": "latest",
    "prisma": "^6.19.3",
    "supertest": "^7.2.2",
    "typescript": "^5.8.2"
  }
}
